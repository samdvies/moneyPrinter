{
  "install": "curl -LsSf https://astral.sh/uv/install.sh | sh && ~/.local/bin/uv sync --all-packages && cp -n .env.example .env",
  "start": "docker compose up -d && ~/.local/bin/uv run python -m scripts.migrate",
  "terminals": [
    {
      "name": "tests",
      "command": "~/.local/bin/uv run pytest -q"
    }
  ]
}
