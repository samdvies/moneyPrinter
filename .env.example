# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algobet
POSTGRES_USER=algobet
POSTGRES_PASSWORD=devpassword

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service identity (used by bus consumer groups)
SERVICE_NAME=ingestion-dev
INGESTION_MODE=betfair

# Betfair ingestion (Phase 2)
# Leave these unset in shared/dev CI environments without credentials.
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERTS_DIR=
BETFAIR_MARKET_IDS_CSV=
BETFAIR_STREAM_CONFLATE_MS=0
BETFAIR_RECONNECT_DELAY_SECONDS=5
BETFAIR_POLL_INTERVAL_SECONDS=0.25

# Kalshi ingestion scaffold (Phase 2b)
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_ENVIRONMENT=demo

# LLM provider (Phase 6c — agentic hypothesis generation)
# xAI Grok API is OpenAI-compatible; use the `openai` SDK with base_url=https://api.x.ai/v1
XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning

# Rust execution service (Phase 7a)
# Use `mock` locally unless explicitly testing the Smarkets adapter.
VENUE=mock
EXECUTION_CONSUMER_NAME=execution-mock-1
MAX_TRACKED_ORDERS=10000
SHUTDOWN_DRAIN_SECONDS=30

# Smarkets execution adapter (required when VENUE=smarkets)
SMARKETS_USERNAME=
SMARKETS_PASSWORD=
SMARKETS_BASE_URL=https://api.smarkets.com/v3
SMARKETS_RATE_LIMIT_RPS=5
SMARKETS_RATE_LIMIT_BURST=10
